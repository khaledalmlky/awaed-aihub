# ============================================
# متغيرات البيئة المطلوبة (Environment Variables)
# ============================================
# انسخ هذا الملف إلى .env واملأ القيم
# cp .env.example .env

# -------- قاعدة البيانات PostgreSQL --------
# Railway سيوفر هذا تلقائياً عند إضافة PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/database

# -------- OpenAI --------
# احصل على المفتاح من: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# -------- حساب الأدمن الافتراضي --------
# سيتم إنشاؤه تلقائياً عند أول تشغيل للخادم
ADMIN_EMAIL=admin@awaed.com
ADMIN_PASSWORD=ChangeMe_StrongPassword123!

# -------- Session Secret --------
# استخدم نص عشوائي قوي. يمكن توليده بـ:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string

# -------- نظام التعلم الداخلي (اختياري) --------
LEARNING_ENABLED=true
LEARNING_TTL_DAYS=90

# -------- بيئة التشغيل --------
# Railway يضبطه تلقائياً في الإنتاج
NODE_ENV=development

# -------- المنفذ (Port) --------
# Railway يوفره تلقائياً - لا تغيّره في الإنتاج
PORT=5000
